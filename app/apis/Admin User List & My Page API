from enum import Enum
from typing import List, Optional

from fastapi import APIRouter, Depends, HTTPException, Query, status
from fastapi.security import HTTPAuthorizationCredentials, HTTPBearer
from pydantic import BaseModel, ConfigDict, EmailStr
from sqlalchemy.orm import Session

# DB 및 모델 import (프로젝트 구조에 맞게 유치)
from database import get_db
from models import User

# ==========================================
# 1. Pydantic Schemas (스키마 정의)
# ==========================================


class DepartmentEnum(str, Enum):
    RESEARCH = "RESEARCH"
    MEDICAL = "MEDICAL"
    DEVELOPMENT = "DEVELOPMENT"


class GenderEnum(str, Enum):
    M = "M"
    F = "F"


# 회원 기본 정보 (공통 응답용)
class UserBase(BaseModel):
    id: int
    email: EmailStr
    name: str
    department: DepartmentEnum
    gender: GenderEnum
    phone_number: str
    is_active: bool

    # Pydantic v2 최신 설정 방식 (ORM 객체 변환 지원)
    model_config = ConfigDict(from_attributes=True)


# 1-1. 회원 목록 조회 응답 스키마 (페이지네이션 메타데이터 추가)
class UserListResponse(BaseModel):
    users: List[UserBase]
    total: int
    page: int
    size: int


# 1-2. 마이페이지 조회 응답 스키마
class MyPageResponse(UserBase):
    role: str


# ==========================================
# 2. Dependencies (인증 및 권한 의존성)
# ==========================================

security = HTTPBearer()


def get_current_user(
    credentials: HTTPAuthorizationCredentials = Depends(security),
    db: Session = Depends(get_db),
) -> User:
    token = credentials.credentials

    # 토큰 검증 및 해독 (예시 함수)
    payload = verify_jwt_token(token)
    if not payload:
        raise HTTPException(
            status_code=status.HTTP_401_UNAUTHORIZED,
            detail="로그인이 필요합니다.",
        )

    user = db.query(User).filter(User.id == payload.get("user_id")).first()
    if not user or not user.is_active:
        raise HTTPException(
            status_code=status.HTTP_401_UNAUTHORIZED,
            detail="유효하지 않거나 탈퇴한 사용자입니다.",
        )
    return user


def get_current_admin_user(
    current_user: User = Depends(get_current_user),
) -> User:
    if current_user.role != "ADMIN":
        raise HTTPException(
            status_code=status.HTTP_403_FORBIDDEN,
            detail="이 작업을 수행할 권한이 없습니다.",
        )
    return current_user


# ==========================================
# 3. API Routers (엔드포인트 정의)
# ==========================================

router = APIRouter(prefix="/api/v1", tags=["Users"])


# 3-1. 회원 목록 조회 API (Admin 전용)
@router.get(
    "/admin/users",
    response_model=UserListResponse,
    status_code=status.HTTP_200_OK,
    summary="회원 목록 조회 API",
)
def get_user_list(
    keyword: Optional[str] = Query(
        None, description="이름 또는 이메일 검색"
    ),
    department: Optional[DepartmentEnum] = Query(
        None, description="부서 검색"
    ),
    page: int = Query(1, ge=1, description="페이지 번호"),
    size: int = Query(10, ge=1, le=100, description="페이지 크기"),
    db: Session = Depends(get_db),
    current_admin: User = Depends(get_current_admin_user),
):
    query = db.query(User)

    # 검색 조건 필터링
    if keyword:
        query = query.filter(
            (User.name.contains(keyword)) | (User.email.contains(keyword))
        )
    if department:
        query = query.filter(User.department == department)

    # 전체 데이터 개수 산출 (페이지네이션용)
    total = query.count()

    # 페이지네이션 적용
    offset = (page - 1) * size
    users = query.offset(offset).limit(size).all()

    return {"users": users, "total": total, "page": page, "size": size}


# 3-2. 마이페이지 조회 API (인증 유저 전용)
@router.get(
    "/users/me",
    response_model=MyPageResponse,
    status_code=status.HTTP_200_OK,
    summary="마이페이지 조회 API",
)
def get_my_page(current_user: User = Depends(get_current_user)):
    # get_current_user 의존성에서 이미 인증 및 유저 검증이 끝났으므로
    # DB 추가 조회 없이 바로 반환합니다.
    return current_user
