from typing import Optional
from pydantic import BaseModel, ConfigDict


class UserResponse(BaseModel):
    id: int
    email: str
    name: str
    department: Optional[str] = None
    gender: Optional[str] = None
    phone_number: Optional[str] = None
    status: str  # 예: PENDING, ACTIVE 등 (요구사항의 권한 상태)

    model_config = ConfigDict(from_attributes=True)  # SQLAlchemy 모델 변환용


class UserListResponse(BaseModel):
    items: list[UserResponse]
    total: int
    page: int
    size: int

from typing import Optional
from fastapi import APIRouter, Depends, HTTPException, Query, status
from sqlalchemy import func, select
from sqlalchemy.ext.asyncio import AsyncSession

from app.core.db.databases import async_get_db
# 💡 현재 로그인한 유저 정보를 가져오는 의존성 함수가 있다면 불러와서 적용합니다.
# from app.core.security import get_current_user 
from app.models.user import User
from app.schemas.user import UserListResponse, UserResponse

router = APIRouter(prefix="/api/v1/users", tags=["users"])


# ---------- 1. 마이페이지 조회 (내 정보 조회) ----------

@router.get("/me", response_model=UserResponse, status_code=status.HTTP_200_OK)
async def get_my_profile(
    # current_user: User = Depends(get_current_user), # JWT 기반 인증 적용 시 사용
    user_id: int,  # 만약 토큰 미적용 상태라면 테스트용 Query 파라미터로 받음
    db: AsyncSession = Depends(async_get_db),
) -> User:
    """
    REQ-USER-002 마이페이지 조회
    
    현재 로그인한 본인의 상세 프로필 정보를 조회합니다.
    """
    # current_user가 구현되어 있다면 아래 DB 조회 없이 `return current_user`로 바로 반환 가능합니다.
    user = await db.scalar(select(User).where(User.id == user_id))
    
    if user is None:
        raise HTTPException(
            status_code=status.HTTP_404_NOT_FOUND,
            detail="존재하지 않는 사용자입니다.",
        )
    return user


# ---------- 2. 회원 목록 조회 (페이징 & 검색 옵션) ----------

@router.get("", response_model=UserListResponse, status_code=status.HTTP_200_OK)
async def get_users(
    page: int = Query(1, ge=1, description="페이지 번호"),
    size: int = Query(10, ge=1, le=100, description="페이지당 개수"),
    department: Optional[str] = Query(None, description="부서 필터"),
    db: AsyncSession = Depends(async_get_db),
) -> UserListResponse:
    """
    REQ-USER-003 회원 목록 조회 (관리자/실무진용)
    
    가입된 회원 목록을 페이지네이션 및 부서 필터를 적용하여 조회합니다.
    """
    # Base Query
    query = select(User)

    # 필터 조건 추가 (예: 부서별 검색)
    if department:
        query = query.where(User.department == department)

    # 전체 개수 카운트 쿼리
    count_query = select(func.count()).select_from(query.subquery())
    total = await db.scalar(count_query) or 0

    # 페이지네이션 적용 (Offset & Limit)
    offset = (page - 1) * size
    query = query.offset(offset).limit(size).order_by(User.id.desc())

    # 데이터 조회
    result = await db.scalars(query)
    users = list(result.all())

    return UserListResponse(
        items=users,
        total=total,
        page=page,
        size=size,
    )
